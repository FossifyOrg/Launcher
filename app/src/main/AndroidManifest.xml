<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:installLocation="internalOnly">

    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <uses-permission
        android:name="android.permission.BIND_APPWIDGET"
        tools:ignore="ProtectedPermissions" />

    <uses-permission android:name="android.permission.REQUEST_DELETE_PACKAGES" />
    <uses-permission android:name="android.permission.EXPAND_STATUS_BAR" />

    <uses-permission
        android:name="android.permission.USE_FINGERPRINT"
        tools:node="remove" />

    <!-- LAUNCHPAD M1: Safe web browsing -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <!-- LAUNCHPAD M2: Time tracking (user must grant manually) -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- LAUNCHPAD M2: foreground time-tracking service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />

    <application
        android:name="org.fossify.commons.FossifyApp"
        android:allowBackup="true"
        android:appCategory="productivity"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_launcher_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:name=".activities.SplashActivity"
            android:exported="false"
            android:theme="@style/LauncherTheme" />

        <activity
            android:name=".activities.MainActivity"
            android:clearTaskOnLaunch="true"
            android:configChanges="orientation|keyboardHidden|screenSize"
            android:excludeFromRecents="true"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="portrait"
            android:theme="@style/LauncherTheme">

            <intent-filter>
                <action android:name="android.content.pm.action.CONFIRM_PIN_SHORTCUT" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.SettingsActivity"
            android:configChanges="orientation"
            android:exported="true"
            android:label="@string/settings"
            android:parentActivityName=".activities.MainActivity">

            <intent-filter>
                <action android:name="android.intent.action.APPLICATION_PREFERENCES" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name="org.fossify.commons.activities.AboutActivity"
            android:exported="false"
            android:label="@string/about"
            android:parentActivityName=".activities.SettingsActivity" />

        <activity
            android:name="org.fossify.commons.activities.CustomizationActivity"
            android:exported="false"
            android:label="@string/customize_colors"
            android:parentActivityName=".activities.SettingsActivity" />

        <activity
            android:name=".activities.HiddenIconsActivity"
            android:exported="false"
            android:label="@string/hidden_icons"
            android:parentActivityName=".activities.SettingsActivity" />

        <!-- LAUNCHPAD: Jake's dashboard -->
        <activity
            android:name=".activities.JakeDashboardActivity"
            android:exported="false"
            android:label="Mein Status"
            android:theme="@style/AppTheme" />

        <!-- LAUNCHPAD: Safe browsing (Entdecken-Modus) -->
        <activity
            android:name=".activities.EntdeckenActivity"
            android:exported="false"
            android:label="Entdecken"
            android:theme="@style/AppTheme" />

        <!-- LAUNCHPAD: App whitelist management -->
        <activity
            android:name=".activities.AppsManagementActivity"
            android:exported="false"
            android:label="Apps verwalten"
            android:parentActivityName=".activities.ElternModusActivity" />

        <!-- LAUNCHPAD Setup wizard (first run) -->
        <activity
            android:name=".activities.SetupActivity"
            android:exported="false"
            android:label="Einrichten"
            android:theme="@style/AppTheme" />

        <!-- LAUNCHPAD M1: Parent control interface -->
        <activity
            android:name=".activities.ElternModusActivity"
            android:exported="false"
            android:label="Eltern-Modus"
            android:parentActivityName=".activities.MainActivity" />

        <!-- LAUNCHPAD M1: Cool-down restorative phase -->
        <activity
            android:name=".activities.CooldownActivity"
            android:exported="false"
            android:launchMode="singleInstance"
            android:label="Pause"
            android:theme="@style/AppTheme" />

        <!-- LAUNCHPAD M2: Zusagen (family promises) -->
        <activity
            android:name=".activities.ZusagenActivity"
            android:exported="false"
            android:label="Versprechen"
            android:parentActivityName=".activities.ElternModusActivity" />

        <!-- LAUNCHPAD M2: Doge-Coins (media approvals) -->
        <activity
            android:name=".activities.DogeRequestsActivity"
            android:exported="false"
            android:label="Medien-Anfragen"
            android:parentActivityName=".activities.ElternModusActivity" />

        <!-- LAUNCHPAD M4: parent pairing (QR) -->
        <activity
            android:name=".activities.PairingActivity"
            android:exported="false"
            android:label="Kopplung"
            android:parentActivityName=".activities.ElternModusActivity" />


        <!-- LAUNCHPAD widget -->
        <receiver
            android:name=".helpers.LaunchpadWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_info" />
        </receiver>
        <!-- LAUNCHPAD M2: Time tracking background service -->
        <service
            android:name=".services.TimeTrackingService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

