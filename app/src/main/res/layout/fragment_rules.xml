<?xml version="1.0" encoding="utf-8"?>
<!-- Rules page: shown to Jake when swiping left from home (page 0). -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📜"
            android:textSize="48sp"
            android:gravity="center"
            android:paddingTop="32dp"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Jakes Regeln"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:paddingBottom="32dp" />

        <!-- Rules are inflated programmatically into this container -->
        <LinearLayout
            android:id="@+id/rules_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- Live status card -->
        <LinearLayout
            android:id="@+id/rules_status_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#CC000000"
            android:padding="20dp"
            android:layout_marginTop="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="AKTUELLER STATUS"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#AAAAAA"
                android:letterSpacing="0.1"
                android:paddingBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Verfügbare Zeit"
                    android:textSize="14sp"
                    android:textColor="#CCCCCC" />

                <TextView
                    android:id="@+id/rules_balance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="— Min"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#4CAF50" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Kindermodus"
                    android:textSize="14sp"
                    android:textColor="#CCCCCC" />

                <TextView
                    android:id="@+id/rules_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="14sp"
                    android:textColor="#AAAAAA" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="← Wisch zurück"
            android:textSize="12sp"
            android:textColor="#55FFFFFF"
            android:gravity="center"
            android:paddingTop="32dp"
            android:paddingBottom="16dp" />

    </LinearLayout>
</ScrollView>
