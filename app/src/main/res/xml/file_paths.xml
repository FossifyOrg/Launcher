<?xml version="1.0" encoding="utf-8"?>
<!--
    FileProvider-Konfiguration für LAUNCHPAD.
    Ermöglicht das sichere Teilen von Dateien aus dem internen Speicher
    mit Phyphox (für Experiment-Shortcuts).

    Einbinden in AndroidManifest.xml:
    <provider
        android:name="androidx.core.content.FileProvider"
        android:authorities="${applicationId}.fileprovider"
        android:exported="false"
        android:grantUriPermissions="true">
        <meta-data
            android:name="android.support.FILE_PROVIDER_PATHS"
            android:resource="@xml/file_paths" />
    </provider>
-->
<paths>
    <!-- Phyphox-Experimente aus PhyphoxLaunchHelper (filesDir/phyphox/) -->
    <files-path name="phyphox_experiments" path="phyphox/"/>

    <!-- Offline-KI Modell (filesDir/models/) — für zukünftige Nutzung -->
    <files-path name="ai_models" path="models/"/>
</paths>
